<?xml version="1.0" encoding="utf-8"?>
<Defs>
<!--================ Industrial Apparel ================-->

<!--======== Reichswehr Cap Base ========-->

	<ThingDef ParentName="HatMakeableBase" Name="CFAR_CapBase" Abstract="True">
		<techLevel>Industrial</techLevel>
		<recipeMaker>
			<researchPrerequisite>ComplexClothing</researchPrerequisite>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<statBases>
			<MaxHitPoints>80</MaxHitPoints>
			<WorkToMake>4000</WorkToMake>
			<Mass>0.1</Mass>
			<StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.10</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.40</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>0.5</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.1</SlaveSuppressionOffset>
			<SuppressionPower MayRequire="Ludeon.RimWorld.Ideology">0.1</SuppressionPower>
		</equippedStatOffsets>
		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel" />
		<tradeTags>
			<li>BasicClothing</li>
			<li>CFAR_Apparel</li>
		</tradeTags>
	</ThingDef>

<!--======== Reichswehr Cap ========-->

	<ThingDef ParentName="CFAR_CapBase">
		<defName>Apparel_CFAR_OfficerCap</defName>
		<label>Reichswehr officer cap</label>
		<description>A structured service cap for junior officers, intended for daily field use. Practical and comfortable, it protects against the elements while retaining a clear mark of authority.</description>
		<recipeMaker>
			<displayPriority>1160</displayPriority>
		</recipeMaker>
		<costStuffCount>35</costStuffCount>
		<graphicData>
			<texPath>Things/Pawn/Arellian/Apparel/Uniform/OfficerCap/Hat</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.80</drawSize>
		</graphicData>
		<equippedStatOffsets>
			<PainShockThreshold>0.05</PainShockThreshold>
			<SocialImpact>0.10</SocialImpact>
		</equippedStatOffsets>
		<apparel>
			<wornGraphicPath>Things/Pawn/Arellian/Apparel/Uniform/OfficerCap/Hat</wornGraphicPath>
			<tags>
				<li>CFAR_Officer</li>
			</tags>
		</apparel>
	</ThingDef>

<!--======== Commander Cap ========-->

	<ThingDef ParentName="CFAR_CapBase">
		<defName>Apparel_CFAR_CommanderCap</defName>
		<label>Reichswehr commander cap</label>
		<description>A service cap issued to experienced officers. Its formal profile signifies authority and operational oversight, worn by those entrusted with command beyond the front line.</description>
		<recipeMaker>
			<displayPriority>1161</displayPriority>
		</recipeMaker>
		<costStuffCount>50</costStuffCount>
		<graphicData>
			<texPath>Things/Pawn/Arellian/Apparel/Uniform/CommanderCap/Hat</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.80</drawSize>
		</graphicData>
		<equippedStatOffsets>
			<SocialImpact>0.20</SocialImpact>
		</equippedStatOffsets>
		<apparel>
			<wornGraphicPath>Things/Pawn/Arellian/Apparel/Uniform/CommanderCap/Hat</wornGraphicPath>
			<tags>
				<li>CFAR_OfficerHigh</li>
			</tags>
		</apparel>
	</ThingDef>

<!--======== Arellian Visor Base ========-->

	<ThingDef ParentName="ArmorMachineableBase" Name="CFAR_VisorBase" Abstract="True">
		<techLevel>Spacer</techLevel>
		<uiIconScale>1.15</uiIconScale>
		<recipeMaker>
			<researchPrerequisites>
				<li>MicroelectronicsBasics</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		<thingCategories>
			<li>Headgear</li>
		</thingCategories>
		<costList>
			<Plasteel>15</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
		</costList>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<WorkToMake>5000</WorkToMake>
			<Mass>0.5</Mass>
			<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Heat>0.20</ArmorRating_Heat>
			<EquipDelay>1</EquipDelay>
		</statBases>
		<apparel>
			<wearPerDay>0</wearPerDay>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
			<bodyPartGroups>
				<li>Eyes</li>
			</bodyPartGroups>
			<layers>
				<li>EyeCover</li>
			</layers>
			<parentTagDef>ApparelHead</parentTagDef>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel" />
		<tradeTags>
			<li>BasicClothing</li>
			<li>CFAR_Apparel</li>
		</tradeTags>
	</ThingDef>

<!--======== Combat Visor ========-->

	<ThingDef ParentName="CFAR_VisorBase" MayRequire="Ludeon.RimWorld.Royalty">
		<defName>Apparel_CFAR_VisorCombat</defName>
		<label>combat visor</label>
		<description>WIP</description>
		<recipeMaker>
			<researchPrerequisites>
				<li>Gunlink</li>
			</researchPrerequisites>
			<displayPriority>1160</displayPriority>
		</recipeMaker>
		<graphicData>
			<texPath>Things/Pawn/Arellian/Apparel/VisorCombat/Visor</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.80</drawSize>
		</graphicData>
		<equippedStatOffsets>
			<ShootingAccuracyPawn>2.5</ShootingAccuracyPawn>
			<AimingDelayFactor>-0.25</AimingDelayFactor>
		</equippedStatOffsets>
		<apparel>
			<wornGraphicPath>Things/Pawn/Arellian/Apparel/VisorCombat/Visor</wornGraphicPath>
			<tags>
				<li>CFAR_VisorCombat</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
	</ThingDef>
</Defs>