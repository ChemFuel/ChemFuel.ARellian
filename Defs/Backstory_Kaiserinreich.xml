<!--======== Line Trooper ========-->

	<BackstoryDef ParentName="CFAR_RW_Soldier">
		<defName>CFAR_JagerTrooper1</defName>
		<title>jäger trooper</title>
		<titleShort>jäger</titleShort>
		<description>[PAWN_nameDef] served as a trooper in the Reichswehr Jägerkorps. Whether defending a breach or creating one aboard a hostile vessel, [PAWN_pronoun] was always in the thick of battle.</description>
		<skillGains>
			<Shooting>6</Shooting>
			<Melee>6</Melee>
		</skillGains>
		<spawnCategories>
			<li>CFAR_JagerTrooper</li>
		</spawnCategories>
	</BackstoryDef>

