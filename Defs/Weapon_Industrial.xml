<!--======== BulletDefs ========-->

	<ThingDef Name="Bullet_CFAR_AR" ParentName="BaseBullet">
		<defName>Bullet_CFAR_AR</defName>
		<label>rifle bullet</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>14</damageAmountBase>
			<stoppingPower>1</stoppingPower>
			<armorPenetrationBase>0.2</armorPenetrationBase>
			<speed>70</speed>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Bullet_CFAR_AR">
		<defName>Bullet_CFAR_ARL</defName>
		<projectile>
			<damageAmountBase>28</damageAmountBase>
			<stoppingPower>3</stoppingPower>
			<armorPenetrationBase>0.4</armorPenetrationBase>
			<speed>140</speed>
		</projectile>
	</ThingDef>

