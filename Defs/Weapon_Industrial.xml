				<defaultProjectile>Bullet_CFAR_AR</defaultProjectile>
				<burstShotCount>4</burstShotCount>
				<ticksBetweenBurstShots>9</ticksBetweenBurstShots>
				<warmupTime>0.9</warmupTime>
				<range>32.9</range>
