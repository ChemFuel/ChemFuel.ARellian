					<li>Stab</li>
				</capacities>
				<power>13</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>bayonet</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<tradeTags>
			<li>CFAR_WeaponRanged</li>
		</tradeTags>
	</ThingDef>

