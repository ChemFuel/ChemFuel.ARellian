	<ThingDef ParentName="Base_CFAR_GunIndustrial">
		<defName>Gun_CFAR_ARK</defName>
		<label>Arellian MPK</label>
		<description>A standard-issue Reichswehr submachine gun favored for its compact profile and high rate of fire. It is commonly issued to shipboard security, support personnel, and units operating in confined environments.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/CFAR_SMG</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_SMG</soundInteract>
		<recipeMaker>
			<researchPrerequisite>GasOperation</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<displayPriority>1172</displayPriority>
		</recipeMaker>
		<statBases>
			<WorkToMake>18000</WorkToMake>
			<Mass>2.5</Mass>
			<AccuracyTouch>0.90</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.4</AccuracyMedium>
			<AccuracyLong>0.25</AccuracyLong>
			<RangedWeapon_Cooldown>1.6</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>CFAR_ARK</li>
		</weaponTags>
		<costList>
			<Steel>50</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Bullet_CFAR_AR</defaultProjectile>
				<burstShotCount>3</burstShotCount>
				<ticksBetweenBurstShots>5</ticksBetweenBurstShots>
				<warmupTime>0.75</warmupTime>
				<range>25.9</range>
				<soundCast>Shot_HeavySMG</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>8</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<tradeTags>
			<li>CFAR_WeaponRanged</li>
		</tradeTags>
	</ThingDef>

	<ThingDef ParentName="Base_CFAR_GunIndustrial">
		<defName>Gun_CFAR_AR</defName>
		<label>Arellian Automatic Rifle</label>
		<description>A standard-issue Reichswehr assault rifle engineered for versatility across varied combat environments. While not specialized for any single role, it provides reliable performance in most engagements.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/CFAR_AutoRifle</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<recipeMaker>
			<researchPrerequisite>PrecisionRifling</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
			<displayPriority>1173</displayPriority>
		</recipeMaker>
		<statBases>
			<WorkToMake>45000</WorkToMake>
			<Mass>6</Mass>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.65</AccuracyMedium>
			<AccuracyLong>0.5</AccuracyLong>
			<RangedWeapon_Cooldown>1.80</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>CFAR_AR</li>
		</weaponTags>
		<costList>
			<Steel>75</Steel>
			<Plasteel>25</Plasteel>
			<ComponentIndustrial>7</ComponentIndustrial>
		</costList>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
