		<workerClass>RoyalTitlePermitWorker_CallShuttle</workerClass>
		<minTitle>CFAR_RankE</minTitle><!--Leutnant-->
		<faction>CFAR_Kaiserinreich</faction>
		<permitPointCost>1</permitPointCost>
		<cooldownDays>15</cooldownDays>
