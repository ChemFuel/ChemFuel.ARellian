	</RoyalTitlePermitDef>

	<RoyalTitlePermitDef ParentName="CFAR_ShuttleBase">
		<defName>CFAR_CallShuttleC</defName>
		<minTitle>CFAR_RankH</minTitle><!--Admiralmajor-->
