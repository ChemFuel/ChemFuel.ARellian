<!--======== Rural ========-->

	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_RanchChild1</defName>
		<title>ranch child</title>
		<titleShort>ranchling</titleShort>
		<description>[PAWN_nameDef] grew up on [PAWN_possessive] family's ancestral muffalo ranch. [PAWN_pronoun] learned how to care for animals and distinguish poisonous plants from edible ones. There was little formal education, but the work was steady, the meals were warm, and a fresh glass of muffalo milk at the end of the day was enough.</description>
		<skillGains>
			<Animals>3</Animals>
			<Medicine>1</Medicine>
			<Plants>1</Plants>
			<Intellectual>-2</Intellectual>
		</skillGains>
		<spawnCategories>
			<li>CFAR_Low</li>
		</spawnCategories>
	</BackstoryDef>

