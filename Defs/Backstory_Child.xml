	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_ChildCadet1</defName>
		<title>child cadet</title>
		<titleShort>cadet</titleShort>
		<description>[PAWN_nameDef] enrolled in a youth cadet program at an early age. Drill, first aid, physical training, and teamwork were part of daily life, preparing [PAWN_objective] for military service long before adulthood.</description>
