<!--======== Slum ========-->

	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_StreetUrchin1</defName>
		<title>street urchin</title>
		<titleShort>streetling</titleShort>
		<description>[PAWN_nameDef] grew up in the slums, where everything and everyone was potentially hostile. [PAWN_pronoun] couldn't trust anyone with [PAWN_possessive] wounds, and learned how to swing a knife before [PAWN_pronoun] could properly speak.</description>
		<skillGains>
			<Melee>4</Melee>
			<Medicine>2</Medicine>
			<Social>-2</Social>
		</skillGains>
		<workDisables>
			<li>Artistic</li>
			<li>Intellectual</li>
		</workDisables>
		<spawnCategories>
			<li>CFAR_None</li>
			<li>CFAR_Pirate</li>
		</spawnCategories>
	</BackstoryDef>

	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_StreetPerformer1</defName>
		<title>street performer</title>
		<titleShort>streetling</titleShort>
		<description>[PAWN_nameDef] was a child performer. [PAWN_pronoun] would approach families or groups of soldiers with a charming smile, performing parlor tricks and making them laugh—earning bread in [PAWN_possessive] jar in exchange.</description>
		<skillGains>
			<Artistic>3</Artistic>
			<Social>3</Social>
			<Intellectual>-2</Intellectual>
		</skillGains>
		<spawnCategories>
			<li>CFAR_None</li>
		</spawnCategories>
	</BackstoryDef>

