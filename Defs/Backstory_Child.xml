	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_StreetUrchin1</defName>
		<title>street urchin</title>
		<titleShort>urchin</titleShort>
		<description>[PAWN_nameDef] grew up in the slums, where [PAWN_pronoun] learned how to swing a knife before [PAWN_pronoun] could properly speak. With everything and everyone potentially hostile, [PAWN_pronoun] couldn't trust anyone with [PAWN_possessive] wounds.</description>
		<skillGains>
			<Melee>4</Melee>
			<Medicine>2</Medicine>
			<Social>-2</Social>
			<Intellectual>-4</Intellectual>
		</skillGains>
		<requiredWorkTags>
			<li>Violent</li>
