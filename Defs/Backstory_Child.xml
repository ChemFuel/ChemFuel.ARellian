<!--======== Pirate ========-->

	<BackstoryDef ParentName="CFAR_Child">
		<defName>CFAR_PirateChild1</defName>
		<title>pirate child</title>
		<titleShort>pirateling</titleShort>
		<description>[PAWN_nameDef] was raised to believe the law was for other people. At least, that's what [PAWN_possessive] parents taught [PAWN_objective]. The captain's rules were different. No one was above those. Well...except the captain.</description>
		<skillGains>
			<Shooting>4</Shooting>
			<Melee>2</Melee>
		</skillGains>
		<workDisables>
			<li>Intellectual</li>
		</workDisables>
		<spawnCategories>
			<li>CFAR_Pirate</li>
		</spawnCategories>
	</BackstoryDef>

