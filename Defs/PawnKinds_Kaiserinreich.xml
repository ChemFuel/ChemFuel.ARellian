		<maxGenerationAge>28</maxGenerationAge>
		<defaultFactionType>CFAR_Kaiserinreich</defaultFactionType>
		<minTitleRequired>CFAR_RankE</minTitleRequired>
		<apparelMoney>9999~9999</apparelMoney>
		<specificApparelRequirements>
			<li>
				<apparelLayer>OnSkin</apparelLayer>
				<stuff>Synthread</stuff>
			</li>
		</specificApparelRequirements>
