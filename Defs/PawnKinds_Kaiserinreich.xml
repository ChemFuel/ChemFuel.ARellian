		<titleRequired>CFAR_RankL</titleRequired>
		<minGenerationAge>20</minGenerationAge>
		<maxGenerationAge>25</maxGenerationAge>
		<apparelTags>
			<li>CFAR_MilitaryPlanetary</li>
		</apparelTags>
		<apparelMoney>2500~3500</apparelMoney>
		<weaponTags Inherit="False">
