<?xml version="1.0" encoding="utf-8"?>
<Defs>
<!--================================ Reichswehr ================================-->

	<PawnKindDef Name="CFAR_KaiserinreichBase" Abstract="True">
		<race>Human</race>
		<defaultFactionType>CFAR_Kaiserinreich</defaultFactionType>
		<minTitleRequired>CFAR_RankA</minTitleRequired>
		<chemicalAddictionChance>0</chemicalAddictionChance>
		<combatEnhancingDrugsChance>0</combatEnhancingDrugsChance>
		<combatEnhancingDrugsCount>0~0</combatEnhancingDrugsCount>
		<backstoryCryptosleepCommonality>0.05</backstoryCryptosleepCommonality>
		<useFactionXenotypes>false</useFactionXenotypes>
		<xenotypeSet><xenotypeChances>
			<CFAR_Arellian>999</CFAR_Arellian>
		</xenotypeChances></xenotypeSet>
		<initialResistanceRange>5~10</initialResistanceRange>
		<initialWillRange>0.5~1</initialWillRange>
	</PawnKindDef>

<!--================================ Reichswehr ================================-->

	<PawnKindDef Name="CFAR_SoldierBase" ParentName="CFAR_KaiserinreichBase" Abstract="True">
		<combatPower>150</combatPower>
		<minGenerationAge>20</minGenerationAge>
		<maxGenerationAge>30</maxGenerationAge>
		<defaultFactionType>CFAR_Kaiserinreich</defaultFactionType>
		<minTitleRequired>CFAR_RankB</minTitleRequired>
		<apparelMoney>9999~9999</apparelMoney>
		<specificApparelRequirements>
			<li>
				<colorGenerator Class="ColorGenerator_Options">
					<options>
						<li><only>(0.75,0.75,0.75)</only></li>
					</options>
				</colorGenerator>
			</li>
			<li>
				<apparelLayer>OnSkin</apparelLayer>
				<stuff>Synthread</stuff>
			</li>
		</specificApparelRequirements>
		<weaponMoney>9999~9999</weaponMoney>
		<initialResistanceRange>10~20</initialResistanceRange>
		<initialWillRange>1~2</initialWillRange>
	</PawnKindDef>

	<PawnKindDef Name="CFAR_OfficerBase" ParentName="CFAR_KaiserinreichBase" Abstract="True">
		<combatPower>125</combatPower>
