<?xml version="1.0" encoding="utf-8"?>
<Patch>
<!--======== Hediff: Combat Chip ========-->

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationAdd">
				<xpath>Defs/RaidStrategyDef[defName="StageThenAttack"]/selectionWeightCurvesPerFaction</xpath>
				<value>
					<li>
						<faction>CFAR_Kaiserinreich</faction>
						<selectionWeightPerPointsCurve><points>
							<li>(0, 0)</li> <!-- Constant 0 -->
						</points></selectionWeightPerPointsCurve>
					</li>
				</value>
			</li>
			<li Class="PatchOperationConditional">
				<xpath>Defs/FactionDef[@Name="OutlanderFactionBase"]/pawnGroupMakers/li[1]/options</xpath>
				<match Class="PatchOperationAdd">
					<xpath>Defs/FactionDef[@Name="OutlanderFactionBase"]/pawnGroupMakers/li[1]/options</xpath>
					<value>
						<CFAR_Mercenary>0.01</CFAR_Mercenary>
					</value>
				</match>
			</li>
			<li Class="PatchOperationConditional">
				<xpath>Defs/FactionDef[defName="Pirate"]/pawnGroupMakers/li[1]/options | Defs/FactionDef[defName="Pirate"]/pawnGroupMakers/li[3]/options</xpath>
				<match Class="PatchOperationAdd">
					<xpath>Defs/FactionDef[defName="Pirate"]/pawnGroupMakers/li[1]/options | Defs/FactionDef[defName="Pirate"]/pawnGroupMakers/li[3]/options</xpath>
					<value>
						<CFAR_MercPirate>0.01</CFAR_MercPirate>
					</value>
				</match>
			</li>
		</operations>
	</Operation>
</Patch>
